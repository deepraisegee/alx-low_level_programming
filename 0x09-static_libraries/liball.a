/**
  * _abs - find absolute value of a number
  * @n: an integer
  *
  * Return: an absolute result of a number
  */
int _abs(int n)
{
	if (n < 0)
	{
		n *= -1;
		return (n);
	}
	else
	{
		return (n);
	}
}

