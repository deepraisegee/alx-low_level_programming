/**
  * _puts - prints a string, followed by a new line, to stdout
  * @str: pointer
  *
  * Return: nothing
  */
void _puts(char *str)
{
	int n = 0;

	while (str[n] != '\0')
	{
		_putchar(str[n]);
		n++;
	}

	_putchar('\n');
}
