/**
  * _memcpy - copies memory area
  * @dest: pointer
  * @src: pointer
  * @n: unsigned int
  *
  * Return: pointer
  */
char *_memcpy(char *dest, char *src, unsigned int n)
{
	unsigned int i = 0;

	while (i < n)
	{
		dest[i] = src[i];
		i++;
	}

	return (dest);
}

